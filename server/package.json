{
  "name": "betfusion-server",
  "version": "1.0.0",
  "description": "BetFusion Production Server - Complete Betting Platform",
  "main": "server.js",
  "scripts": {
    "start": "node --max-old-space-size=512 server.js",
    "dev": "nodemon --max-old-space-size=512 server.js",
    "seed": "node seed/production-seed.js",
    "seed:matches": "node seed/matches.js",
    "seed:enhanced": "node seed/enhanced-seed.js",
    "seed:complete": "node seed/complete-seed.js",
    "seed:all": "npm run seed:complete",
    "cleanup": "node scripts/cleanupMatches.js",
    "test": "node test-full-system.js",
    "test:api": "node test-odds-api.js && node test-sportmonks.js",
    "test:betting": "node test-betting.js"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "mongoose-aggregate-paginate-v2": "^1.0.6",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}